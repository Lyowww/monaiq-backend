# Vercel: add the same variable names in Project → Settings → Environment Variables
# (Production / Preview as needed). Use MongoDB Atlas (or other cloud URI), not localhost.
# After saving, trigger a new deployment. Check Runtime Logs if requests still 500.
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/ai_finance?replicaSet=rs0
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
# Google AI: voice transcription and scheduled insights (not the in-app finance assistant chat)
GEMINI_API_KEY=replace_with_google_ai_studio_key
GEMINI_MODEL=gemini-2.0-flash
# Required for POST /api/ai/finance/chat and for POST /api/ai/openrouter/chat — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: override the first model in the built-in Gemma free fallback chain
OPENROUTER_MODEL=google/gemma-3-12b-it:free
# Optional: Go translation sidecar (`translation-app`, default http://127.0.0.1:8000). `npm run start:dev` starts it automatically.
# TRANSLATION_SERVICE_URL=http://127.0.0.1:8000
CRON_SECRET=replace_with_long_random_vercel_cron_secret
# Optional: single-line JSON of Firebase service account for server-side FCM (private_key, client_email, project_id)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
