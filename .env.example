# Copy to `backend/.env` locally (never commit real secrets).
# Vercel / Railway / Render: set the same variable names in the host dashboard.

NODE_ENV=development
PORT=3000

# Atlas or local. For serverless (Vercel, Lambda): use mongodb+srv://... and allow
# 0.0.0.0/0 (or platform IPs) in Atlas → Network Access. URL-encode password if needed.
MONGODB_URI=mongodb://127.0.0.1:27017/ai_finance?replicaSet=rs0

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Google AI: voice transcription and scheduled insights (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# POST /api/ai/finance/chat and POST /api/ai/openrouter/chat — https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-3-12b-it:free

# Optional: protect cron routes (set a long random string in production)
# CRON_SECRET=

# Comma-separated admin emails; optional bootstrap login for empty DB
# ADMIN_EMAILS=
# ADMIN_LOGIN_EMAIL=
# ADMIN_LOGIN_PASSWORD=

# Optional FCM (JSON string of service account)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional Go translation sidecar (`POST /translate`)
# TRANSLATION_SERVICE_URL=http://127.0.0.1:8000

# Optional: serve built admin SPA at /admin (separate deploys: leave unset)
# ADMIN_SPA_ROOT=
