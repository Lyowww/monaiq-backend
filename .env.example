# Copy to `backend/.env` (never commit real secrets).
# Backend runs as its own process or container; mobile and admin point here via their own env files.

NODE_ENV=development
PORT=3000

MONGODB_URI=mongodb://127.0.0.1:27017/ai_finance?replicaSet=rs0

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Optional AI providers
# GEMINI_API_KEY=
# GEMINI_MODEL=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Optional: protect cron routes
# CRON_SECRET=

# Comma-separated admin emails; optional bootstrap login for empty DB
# ADMIN_EMAILS=
# ADMIN_LOGIN_EMAIL=
# ADMIN_LOGIN_PASSWORD=

# Optional FCM (JSON string of service account)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional Go translation sidecar
# TRANSLATION_SERVICE_URL=http://127.0.0.1:8000

# Optional: serve built admin SPA from this folder at /admin (separate deploys: leave unset)
# ADMIN_SPA_ROOT=
