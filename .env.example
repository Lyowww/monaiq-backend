# Copy to `backend/.env` locally (never commit real secrets).
# Vercel / Railway / Render: set the same variable names in the host dashboard.
#
# Vercel: Project → Settings → Build & Development → Output Directory must be EMPTY
# (not `dist`). Otherwise the CDN serves static files only, you get 404 NOT_FOUND, and
# Functions/runtime logs stay empty — no request reaches Node.
#
# Vercel cold start (Nest + Mongo) can exceed the Hobby function time limit (~10s). If deploys
# time out or hang, use a Pro plan (longer maxDuration, see vercel.json), or run this API on a
# long-lived host (Docker/Railway/Render) where `npm start` + `Dockerfile` are a better fit.

NODE_ENV=development
PORT=3000

# Atlas or local. For serverless (Vercel, Lambda): use mongodb+srv://... and allow
# 0.0.0.0/0 (or platform IPs) in Atlas → Network Access. URL-encode password if needed.
MONGODB_URI=mongodb://127.0.0.1:27017/ai_finance?replicaSet=rs0

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# Google AI: voice transcription and scheduled insights (optional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# POST /api/ai/finance/chat and POST /api/ai/openrouter/chat — https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-3-12b-it:free
# Optional: OpenRouter rankings (your public site URL)
# OPENROUTER_HTTP_REFERER=https://your-app.example

# Optional: protect cron routes (set a long random string in production)
# CRON_SECRET=

# Comma-separated admin emails; optional bootstrap login for empty DB
# ADMIN_EMAILS=
# ADMIN_LOGIN_EMAIL=
# ADMIN_LOGIN_PASSWORD=

# Optional FCM (JSON string of service account)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Translation for HY↔EN in AI routes (default: monaiq-translator + Bearer token)
# TRANSLATION_API_URL=https://monaiq-translator.vercel.app/api/admin/translate
# TRANSLATION_ACCESS_TOKEN=random-token
# Legacy full URL to another translator that returns { status, translatedText }
# TRANSLATION_SERVICE_URL=

# Optional: serve built admin SPA at /admin (separate deploys: leave unset)
# ADMIN_SPA_ROOT=
